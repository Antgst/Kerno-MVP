{
  "info": {
    "name": "Kerno MVP - Issue #36 API Tests",
    "description": "Postman collection for testing the main Kerno API flow: health, auth, profiles, categories, products and contact requests. Built for issue #36; documentation can stay separate.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "supplierEmail",
      "value": "",
      "type": "string"
    },
    {
      "key": "storeEmail",
      "value": "",
      "type": "string"
    },
    {
      "key": "testPassword",
      "value": "Password123!",
      "type": "string"
    },
    {
      "key": "supplierToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "storeToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "supplierUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "storeUserId",
      "value": "",
      "type": "string"
    },
    {
      "key": "supplierProfileId",
      "value": "",
      "type": "string"
    },
    {
      "key": "storeProfileId",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "",
      "type": "string"
    },
    {
      "key": "requestId",
      "value": "",
      "type": "string"
    }
