    {
      "name": "03 - Contact request flow",
      "item": [
        {
          "name": "Create contact request as store",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Cookie",
                "value": "kerno_auth_token={{storeCookie}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/requests",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "requests"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{{contactRequestPayload}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get(\"storeCookie\")) {",
                  "  throw new Error(\"Missing storeCookie. Store login must run first.\");",
                  "}",
                  "if (!pm.environment.get(\"supplierId\")) {",
                  "  throw new Error(\"Missing supplierId. Supplier discovery must run first.\");",
                  "}",
                  "",
                  "const payload = {",
                  "  supplierId: pm.environment.get(\"supplierId\"),",
                  "  subject: \"Newman MVP regression request\",",
                  "  message: \"Automated Newman regression check for the KERNO MVP API.\",",
                  "  requestedQuantity: \"10 colis\"",
                  "};",
                  "",
                  "const productId = pm.environment.get(\"productId\");",
                  "if (productId) {",
                  "  payload.productId = productId;",
                  "}",
                  "",
                  "pm.environment.set(\"contactRequestPayload\", JSON.stringify(payload, null, 2));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is [200, 201]\", function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test(\"Response is JSON\", function () {",
                  "  pm.expect(pm.response.headers.get(\"Content-Type\") || \"\").to.include(\"application/json\");",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "if (Object.prototype.hasOwnProperty.call(json, \"success\")) {",
                  "  pm.test('success is true when present', function () {",
                  "    pm.expect(json.success).to.eql(true);",
                  "  });",
                  "}",
                  "var json = pm.response.json();",
                  "var payload = json.data || json;",
                  "var request = payload.request || payload.contactRequest || payload;",
                  "pm.test(\"Created request has an id\", function () {",
                  "  pm.expect(request.id).to.be.a(\"string\").and.not.empty;",
                  "});",
                  "pm.environment.set(\"requestId\", request.id || \"\");"
                ]
              }
            }
          ]
        },
        {
          "name": "List store sent requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "kerno_auth_token={{storeCookie}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/requests/sent",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "requests",
                "sent"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
