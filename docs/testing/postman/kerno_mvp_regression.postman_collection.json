{
  "info": {
    "name": "KERNO MVP API Regression",
    "_postman_id": "kerno-mvp-api-regression",
    "description": "Complementary Postman/Newman smoke regression collection for the KERNO MVP API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Public API checks",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is JSON\", function () {",
                  "  pm.expect(pm.response.headers.get(\"Content-Type\") || \"\").to.include(\"application/json\");",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "if (Object.prototype.hasOwnProperty.call(json, \"success\")) {",
                  "  pm.test('success is true when present', function () {",
                  "    pm.expect(json.success).to.eql(true);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
