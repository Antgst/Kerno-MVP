                  "var json = pm.response.json();",
                  "var payload = json.data || json;",
                  "var setCookie = pm.response.headers.get(\"Set-Cookie\") || \"\";",
                  "pm.test(\"Supplier session cookie is returned\", function () {",
                  "  pm.expect(setCookie).to.include(\"kerno_auth_token=\");",
                  "});",
                  "var match = setCookie.match(/kerno_auth_token=([^;]+)/);",
                  "if (match) pm.environment.set(\"supplierCookie\", match[1]);",
