                  "var json = pm.response.json();",
                  "var payload = json.data || json;",
                  "const products = Array.isArray(payload) ? payload : (payload.products || payload.items || []);",
                  "pm.test(\"Products payload is a non-empty list\", function () {",
                  "  pm.expect(products).to.be.an(\"array\");",
                  "  pm.expect(products.length).to.be.above(0);",
                  "});",
                  "",
                  "const product =",
                  "  products.find((item) => item && item.id && (item.supplierId || item.supplier?.id || item.supplier?.profile?.id || item.supplier?.supplierId)) ||",
                  "  products.find((item) => item && item.id) ||",
                  "  {};",
                  "",
                  "pm.environment.set(\"productId\", product.id || \"\");",
                  "",
                  "const supplierId =",
                  "  product.supplierId ||",
                  "  product.supplier?.id ||",
                  "  product.supplier?.profile?.id ||",
                  "  product.supplier?.supplierId ||",
                  "  \"\";",
                  "",
                  "if (supplierId) {",
                  "  pm.environment.set(\"supplierId\", supplierId);",
                  "}"
                ]
              }
            }
