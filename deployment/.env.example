# Credentials for the PostgreSQL container. Generate a long, unique password.
POSTGRES_USER=kerno_user
POSTGRES_PASSWORD=replace_with_a_long_random_password
POSTGRES_DB=kerno_db

# Application secrets and public URL.
JWT_SECRET=replace_with_a_long_random_secret
CORS_ORIGIN=https://app.example.com
AUTH_COOKIE_SAMESITE=lax
ENABLE_API_DOCS=false

# The host port used by a reverse proxy (Nginx, Caddy, Traefik, etc.).
APP_PORT=5000

# Persistent host paths. The defaults are appropriate when this file is under
# /home/ausa/kerno-mvp/data.
POSTGRES_DATA_PATH=./data/postgres
UPLOADS_DATA_PATH=./data/uploads
